# Bearer token required for authenticated write endpoints in production
# (strategies, IPO alert preferences, strategy-assistant).
# AI Research Copilot (/api/copilot) is a public research Q&A endpoint and does NOT require this.
API_SECRET=

# Optional: xAI / SpaceXAI key for prose polish of verified copilot answers.
# Without this key, Copilot still works using structured verified data engines.
# Never commit real keys. Server-side only — never expose to the browser.
# Get a key: https://console.x.ai
XAI_API_KEY=
# Optional model override (default: grok-4.5)
# XAI_MODEL=grok-4.5

# Vercel KV — persistent storage for audit logs, strategies, FII history (recommended for production)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Optional custom writable data directory (local dev / self-hosted)
ABC_DATA_DIR=

# Optional override for audit probe scripts
# ABC_BASE=http://localhost:4000