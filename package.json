{
  "name": "abc-research-platform",
  "version": "2.0.0",
  "description": "ABC — institutional-grade financial research and market intelligence platform (Next.js)",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev -p 4000",
    "dev:clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\" && next dev -p 4000",
    "build": "next build",
    "start": "next start -p 4000",
    "lint": "next lint",
    "test": "node --test tests/**/*.test.js",
    "legacy:server": "node server.js"
  },
  "dependencies": {
    "@vercel/kv": "^3.0.0",
    "chart.js": "^4.5.1",
    "chartjs-chart-financial": "^0.2.1",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "ml-regression": "^6.3.0",
    "next": "^15.3.3",
    "pdfkit": "^0.19.1",
    "react": "^19.1.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "eslint": "^9.28.0",
    "eslint-config-next": "^15.3.3"
  }
}
